      "text": "Four capabilities set Aurora apart from batch tooling.",
      "image": {
        "type": "slide",
        "slide": {
          "layout": "grid",
          "accentColor": "accent",
          "title": "What You Get",
          "subtitle": "Core capabilities at a glance",
