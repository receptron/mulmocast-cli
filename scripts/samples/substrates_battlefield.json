            {
              "title": "L2: Substrate Manufacturing",
              "accentColor": "accent",
              "content": [
                {
                  "type": "bullets",
                  "items": [
                    "Glass: Absolics, Samsung SEMCO, DNP, JNTC",
                    "Organic: Unimicron, Ibiden, Shinko, AT&S",
                    "Organic makers running glass R&D as hedge"
                  ]
                }
              ]
            },
            {
              "title": "L3–L4: Packaging & End Demand",
              "accentColor": "warning",
              "content": [
                {
                  "type": "bullets",
