                    "Oligopoly — benefits from any glass expansion",
                    "Ajinomoto monopoly on ABF (organic side)"
                  ]
                }
              ]
            },
            {
              "title": "L1: Processing & Equipment",
              "accentColor": "primary",
              "content": [
                {
                  "type": "bullets",
                  "items": ["TGV formation: SoulBrain, JWMT, Philoptics", "Display players: Samsung Display, BOE", "Large-area glass processing expertise"]
                }
              ]
